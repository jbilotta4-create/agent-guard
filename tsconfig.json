{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": false,
    "sourceMap": false,
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "paths": {
      "openclaw/plugin-sdk/*": ["/usr/lib/node_modules/openclaw/dist/plugin-sdk/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
